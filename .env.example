# TestRail API Configuration
# Copy this file to .env and fill in your credentials

# Your TestRail instance URL (without trailing slash)
TESTRAIL_URL="https://your-company.testrail.io"

# Your TestRail email address
TESTRAIL_USER="your@email.com"

# Your TestRail API key
# Get it from: My Settings → API Keys
# Important: Keep this secret! Never commit .env to git
TESTRAIL_API_KEY="your-api-key-here"
